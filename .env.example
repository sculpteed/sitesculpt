# Required — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Required — Stripe secret key, get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Required — Stripe Price IDs for each tier. Create products in the Stripe
# dashboard (Products → + Add product) then copy the price IDs here.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Required — session cookie signing key. Generate once:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-64-char-hex-string-generated-with-openssl

# Required — absolute URL of this deployment. Used by Stripe for redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Optional — override model IDs
# OPENAI_IMAGE_MODEL=gpt-image-1.5
# OPENAI_VIDEO_MODEL=sora-2
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — fal.ai API key. Get one at https://fal.ai/dashboard/keys.
# When set, the keyframe step routes to fal (Ideogram v3, often higher
# fidelity for text-bearing scenes), and brand-asset compositing becomes
# available. Without it, the pipeline falls back to OpenAI image gen with
# zero behavior change vs. before.
# FAL_API_KEY=

# Optional — image provider routing. `auto` (default) picks fal when
# FAL_API_KEY is set and falls back to OpenAI on missing key or runtime
# error. Force a single provider with `openai` or `fal` to make failures
# loud (no silent fallback).
# IMAGE_PROVIDER=auto

# Optional — Vercel Blob token. Required in prod for cross-instance
# project cache; not needed locally (falls back to .cache/projects/).
# Get from: Vercel Dashboard → Storage → Create Blob Store → Tokens
# BLOB_READ_WRITE_TOKEN=
